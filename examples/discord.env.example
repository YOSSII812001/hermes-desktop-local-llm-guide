# Discord Messaging Gateway example.
# Copy values into the local secret store or the actual .env used by Hermes.
# Do not commit real values.

DISCORD_BOT_TOKEN=replace_with_discord_bot_token
DISCORD_ALLOWED_USERS=replace_with_numeric_discord_user_id

# DM-only operation:
# Prefer sending a DM to the Bot and running /sethome in that DM.
# Set this only if Hermes requires a home channel value explicitly.
DISCORD_HOME_CHANNEL=replace_with_dm_channel_id_if_needed

# Use the Desktop config directory for the Gateway too.
HERMES_CONFIG_DIR=%LOCALAPPDATA%\hermes
